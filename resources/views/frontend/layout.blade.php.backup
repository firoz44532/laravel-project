<!-- Voice System Preload -->
    <script>
        // Voice system initialization
        window.voiceSystemReady = false;
        window.voiceSystemLoaded = false;
        
        // Simple inline voice system as fallback
        window.SimpleVoiceSystem = {
            isEnabled: true,
            synth: null,
            voices: [],
            
            init: function() {
                if ('speechSynthesis' in window) {
                    this.synth = window.speechSynthesis;
                    this.voices = this.synth.getVoices();
                    console.log('Simple voice system initialized');
                    return true;
                }
                return false;
            },
            
            speak: function(text, options = {}) {
                if (!this.isEnabled || !this.synth) return;
                
                try {
                    this.synth.cancel();
                    const utterance = new SpeechSynthesisUtterance(text);
                    utterance.volume = options.volume || 0.8;
                    utterance.rate = options.rate || 1.0;
                    utterance.pitch = options.pitch || 1.0;
                    this.synth.speak(utterance);
                } catch (e) {
                    console.error('Speech error:', e);
                }
            },
            
            toggle: function() {
                this.isEnabled = !this.isEnabled;
                if (this.isEnabled) {
                    this.speak('Voice enabled');
                }
                return this.isEnabled;
            }
        };
        
        // Initialize simple voice system immediately
        if (window.SimpleVoiceSystem.init()) {
            window.voiceSystemLoaded = true;
            window.VoiceNotifications = window.SimpleVoiceSystem;
            window.voiceSystem = window.SimpleVoiceSystem;
            console.log('Simple voice system loaded successfully');
        }
        
        // Try to load full voice system when scripts are loaded
        window.addEventListener('load', function() {
            setTimeout(function() {
                if (window.VoiceNotifications && window.VoiceNotifications !== window.SimpleVoiceSystem) {
                    window.voiceSystemLoaded = true;
                    console.log('Full voice system loaded successfully');
                    
                    // Update button state
                    const button = document.getElementById('voice-control-button');
                    if (button) {
                        const icon = button.querySelector('i');
                        if (window.voiceSystem.isEnabled) {
                            button.style.backgroundColor = '#10B981';
                            icon.className = 'fas fa-microphone';
                        } else {
                            button.style.backgroundColor = '#EF4444';
                            icon.className = 'fas fa-microphone-slash';
                        }
                    }
                } else if (window.SimpleVoiceSystem.init()) {
                    console.log('Using simple voice system');
                    window.VoiceNotifications = window.SimpleVoiceSystem;
                    window.voiceSystem = window.SimpleVoiceSystem;
                    window.voiceSystemLoaded = true;
                } else {
                    console.error('Voice system failed to load');
                }
            }, 500);
        });
    </script>
